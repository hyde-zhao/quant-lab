# QMT Windows Gateway / CR-020 示例环境变量。
# 复制为本地未跟踪 `.env` 后再填写真实值；不要把真实账号、密码、token、session 或私钥提交到 Git。

# S 端 Windows gateway 监听配置。
QMT_GATEWAY_HOST=<qmt-gateway-host-placeholder>
QMT_GATEWAY_PORT=<qmt-gateway-port-placeholder>
QMT_GATEWAY_ALLOWED_SOURCE=<linux-client-ip-or-cidr-placeholder>
QMT_GATEWAY_LOG_DIR=<windows-log-dir-placeholder>

# QMT / MiniQMT / XtQuant 登录配置。真实值只允许写入本地未跟踪 `.env`。
QMT_CREDENTIAL_REF=<qmt-credential-ref-placeholder>
QMT_LOGIN_ACCOUNT=<qmt-login-account-placeholder>
QMT_LOGIN_PASSWORD=<qmt-login-password-placeholder>
QMT_ACCOUNT_REF=<qmt-account-ref-placeholder>
QMT_ACCOUNT_TYPE=<qmt-account-type-placeholder>
QMT_XTQUANT_SITE_PACKAGES=<qmt-xtquant-site-packages-parent-placeholder>
QMT_MINIQMT_PATH=<qmt-miniqmt-userdata-path-placeholder>
QMT_RUNTIME_REF=<qmt-runtime-ref-placeholder>
QMT_SESSION_READY_TIMEOUT_SECONDS=<session-ready-timeout-seconds-placeholder>
QMT_SESSION_TTL_SECONDS=<session-ttl-seconds-placeholder>

# C 端 Linux 调用 gateway 的鉴权配置。
QMT_CLIENT_ID=<qmt-client-id-placeholder>
QMT_CLIENT_SECRET=<qmt-client-secret-placeholder>
QMT_AUTH_MODE=<qmt-auth-mode-placeholder>
QMT_FIRST_QUERY_ENDPOINT=<query-positions-placeholder>

# 运行边界。CR-020 只允许只读查询，不授权交易、撤单、账户写入、simulation 或 live。
QMT_READONLY_ONLY=<true-placeholder>
QMT_DISABLE_ORDER_ENDPOINTS=<true-placeholder>

# 真实数据源凭据。真实 token/password 只允许写入本地未跟踪 `.env`。
TUSHARE_TOKEN=<tushare-token-placeholder>

# 本机主数据湖。项目读写本机目录，NAS 只作为 rsync 同步目标。
MARKET_DATA_LAKE_ROOT=<local-quant-lab-data-lake-root>
MARKET_DATA_LAKE_ARCHIVE_ROOT=<local-quant-lab-archive-root>
MARKET_DATA_LAKE_BACKUP_ROOT=<local-quant-lab-backup-root>
MARKET_DATA_LAKE_RESTORE_ROOT=<local-quant-lab-restore-root>
QUANT_LAB_RESEARCH_ROOT=<local-quant-lab-research-root>
QUANT_LAB_RESEARCH_REPORTS_ROOT=<local-quant-lab-research-reports-root>
QUANT_LAB_RESEARCH_RUNS_ROOT=<local-quant-lab-research-runs-root>
QUANT_LAB_EXPERIMENTS_ROOT=<local-quant-lab-experiments-root>
QUANT_LAB_NOTEBOOK_OUTPUTS_ROOT=<local-quant-lab-notebooks-root>
QUANT_LAB_RESEARCH_EXTRA_SOURCES=<research-extra-sources-placeholder>

# NAS rsync daemon 同步配置。真实用户名和密码只允许写入本地未跟踪 `.env`。
MARKET_DATA_NAS_IP=<nas-ip-placeholder>
MARKET_DATA_NAS_USERNAME=<nas-username-placeholder>
MARKET_DATA_NAS_PASSWORD=<nas-password-placeholder>
MARKET_DATA_NAS_RSYNC_MODE=<nas-rsync-mode-placeholder>
MARKET_DATA_NAS_RSYNC_PORT=<nas-rsync-port-placeholder>
MARKET_DATA_NAS_RSYNC_MODULE=<rsync-daemon-module-placeholder>
MARKET_DATA_NAS_RSYNC_LAKE_TARGET=<nas-rsync-lake-target-placeholder>
MARKET_DATA_NAS_RSYNC_RESEARCH_TARGET=<nas-rsync-research-target-placeholder>
MARKET_DATA_NAS_RSYNC_DELETE=<nas-rsync-delete-placeholder>
