# QMT Windows Gateway / CR-020 示例环境变量。
# 复制为本地未跟踪 `.env` 后再填写真实值；不要把真实账号、密码、token、session 或私钥提交到 Git。

# S 端 Windows gateway 监听配置。
QMT_GATEWAY_HOST=<qmt-gateway-host-placeholder>
QMT_GATEWAY_PORT=<qmt-gateway-port-placeholder>
QMT_GATEWAY_ALLOWED_SOURCE=<linux-client-ip-or-cidr-placeholder>
QMT_GATEWAY_LOG_DIR=<windows-log-dir-placeholder>

# QMT / MiniQMT / XtQuant 登录配置。真实值只允许写入本地未跟踪 `.env`。
QMT_CREDENTIAL_REF=<qmt-credential-ref-placeholder>
QMT_LOGIN_ACCOUNT=<qmt-login-account-placeholder>
QMT_LOGIN_PASSWORD=<qmt-login-password-placeholder>
QMT_ACCOUNT_REF=<qmt-account-ref-placeholder>
QMT_ACCOUNT_TYPE=<qmt-account-type-placeholder>
QMT_MINIQMT_PATH=<qmt-miniqmt-userdata-path-placeholder>
QMT_RUNTIME_REF=<qmt-runtime-ref-placeholder>
QMT_SESSION_READY_TIMEOUT_SECONDS=<session-ready-timeout-seconds-placeholder>
QMT_SESSION_TTL_SECONDS=<session-ttl-seconds-placeholder>

# C 端 Linux 调用 gateway 的鉴权配置。
QMT_CLIENT_ID=<qmt-client-id-placeholder>
QMT_CLIENT_SECRET=<qmt-client-secret-placeholder>
QMT_AUTH_MODE=<qmt-auth-mode-placeholder>
QMT_FIRST_QUERY_ENDPOINT=<query-positions-placeholder>

# 运行边界。CR-020 只允许只读查询，不授权交易、撤单、账户写入、simulation 或 live。
QMT_READONLY_ONLY=<true-placeholder>
QMT_DISABLE_ORDER_ENDPOINTS=<true-placeholder>
